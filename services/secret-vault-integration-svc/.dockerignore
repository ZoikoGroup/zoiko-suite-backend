# .dockerignore for secret-vault-integration-svc
# Keep the build context lean — only source files go to the builder stage.

# Test artifacts
**/*_test.go
**/testdata/

# IDE / OS noise
.idea/
.vscode/
**/.DS_Store
**/Thumbs.db

# Deployment files that are not needed inside the image
deployments/

# Local vault store — never bake dev secret material into an image
secret_store.local

# Documentation
context.md
progress.md

# Git metadata
.git/
.gitignore
