{
  "info": {
    "name": "configuration-feature-flag-svc",
    "description": "Manual verification requests for POST/GET /v1/config and /v1/flags. Run in order within each folder to exercise the versioning (create -> read -> new version -> read again) and idempotency (retry same value) behavior.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8086" },
    { "key": "tenant_id", "value": "11111111-1111-1111-1111-111111111111" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /healthz",
          "request": { "method": "GET", "url": "{{base_url}}/healthz" }
        },
        {
          "name": "GET /readyz",
          "request": { "method": "GET", "url": "{{base_url}}/readyz" }
        }
      ]
    },
    {
      "name": "Config",
      "item": [
        {
          "name": "1. POST /v1/config (create, 201 expected)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/v1/config",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"key\": \"payroll.batch_size\",\n  \"value\": 100,\n  \"environment\": \"staging\",\n  \"created_by_principal_id\": \"admin-1\"\n}"
            }
          }
        },
        {
          "name": "2. GET /v1/config/{key} (200, value=100)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/v1/config/payroll.batch_size?environment=staging"
          }
        },
        {
          "name": "3. POST /v1/config (identical retry, 200 no-op expected)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/v1/config",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"key\": \"payroll.batch_size\",\n  \"value\": 100,\n  \"environment\": \"staging\",\n  \"created_by_principal_id\": \"admin-1\"\n}"
            }
          }
        },
        {
          "name": "4. POST /v1/config (new value, 201 expected)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/v1/config",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"key\": \"payroll.batch_size\",\n  \"value\": 200,\n  \"environment\": \"staging\",\n  \"created_by_principal_id\": \"admin-1\"\n}"
            }
          }
        },
        {
          "name": "5. GET /v1/config/{key} (200, value now 200)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/v1/config/payroll.batch_size?environment=staging"
          }
        },
        {
          "name": "6. GET /v1/config/{key} (404 - missing key)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/v1/config/does.not.exist?environment=staging"
          }
        },
        {
          "name": "7. GET /v1/config/{key} (400 - missing environment)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/v1/config/payroll.batch_size"
          }
        },
        {
          "name": "8. POST /v1/config tenant-scoped override (201)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/v1/config",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"key\": \"payroll.batch_size\",\n  \"value\": 999,\n  \"environment\": \"staging\",\n  \"tenant_id\": \"{{tenant_id}}\",\n  \"created_by_principal_id\": \"admin-1\"\n}"
            }
          }
        },
        {
          "name": "9. GET /v1/config/{key} tenant-scoped (200, value=999, global untouched)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/v1/config/payroll.batch_size?environment=staging&tenant_id={{tenant_id}}"
          }
        },
        {
          "name": "10. GET /v1/config (list all, 200 array)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/v1/config?environment=staging"
          }
        },
        {
          "name": "11. POST /v1/config (400 - missing field)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/v1/config",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"key\": \"payroll.batch_size\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Feature Flags",
      "item": [
        {
          "name": "1. POST /v1/flags (create, 201 expected)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/v1/flags",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"key\": \"new_payroll_ui\",\n  \"enabled\": true,\n  \"environment\": \"staging\",\n  \"rollout_percentage\": 50,\n  \"created_by_principal_id\": \"admin-1\"\n}"
            }
          }
        },
        {
          "name": "2. GET /v1/flags/{key} (200, rollout=50)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/v1/flags/new_payroll_ui?environment=staging"
          }
        },
        {
          "name": "3. POST /v1/flags (identical retry, 200 no-op expected)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/v1/flags",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"key\": \"new_payroll_ui\",\n  \"enabled\": true,\n  \"environment\": \"staging\",\n  \"rollout_percentage\": 50,\n  \"created_by_principal_id\": \"admin-1\"\n}"
            }
          }
        },
        {
          "name": "4. POST /v1/flags (rollout change to 100, 201 expected)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/v1/flags",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"key\": \"new_payroll_ui\",\n  \"enabled\": true,\n  \"environment\": \"staging\",\n  \"rollout_percentage\": 100,\n  \"created_by_principal_id\": \"admin-1\"\n}"
            }
          }
        },
        {
          "name": "5. GET /v1/flags/{key} (200, rollout now 100)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/v1/flags/new_payroll_ui?environment=staging"
          }
        },
        {
          "name": "6. POST /v1/flags (enabled=false explicit, 201 expected)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/v1/flags",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"key\": \"new_payroll_ui\",\n  \"enabled\": false,\n  \"environment\": \"staging\",\n  \"created_by_principal_id\": \"admin-1\"\n}"
            }
          }
        },
        {
          "name": "7. POST /v1/flags (400 - rollout_percentage out of range)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/v1/flags",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"key\": \"bad_flag\",\n  \"enabled\": true,\n  \"environment\": \"staging\",\n  \"rollout_percentage\": 150,\n  \"created_by_principal_id\": \"admin-1\"\n}"
            }
          }
        },
        {
          "name": "8. GET /v1/flags/{key} (404 - missing key)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/v1/flags/does_not_exist?environment=staging"
          }
        },
        {
          "name": "9. GET /v1/flags (list all, 200 array)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/v1/flags?environment=staging"
          }
        }
      ]
    }
  ]
}
