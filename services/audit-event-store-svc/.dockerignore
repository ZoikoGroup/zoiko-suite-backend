# .dockerignore for audit-event-store-svc
# Keep the build context lean — only source files go to the builder stage.

# Test artifacts
**/*_test.go
**/testdata/

# Local dev / embedded-postgres binary cache (downloaded during go test -tags=integration)
**/.embedded-postgres-go/

# IDE / OS noise
.idea/
.vscode/
**/.DS_Store
**/Thumbs.db

# Deployment files that are not needed inside the image
deployments/

# Documentation
docs/

# Git metadata
.git/
.gitignore
