  "item": [
    {
      "name": "🔌 Connectivity API Bridge (8144)",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{connectivity_url}}/healthz",
            "header": [{ "key": "X-Tenant-ID", "value": "{{tenant_id}}" }]
          }
        },
        {
          "name": "Create API Connection",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 201', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('connection_id', body.connection_id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{connectivity_url}}/v1/api-bridge/connections",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Tenant-ID", "value": "{{tenant_id}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"legal_entity_id\": \"{{legal_entity_id}}\",\n  \"provider_name\": \"Xero UK\",\n  \"provider_type\": \"ACCOUNTING\",\n  \"protocol\": \"OAuth2\",\n  \"base_url\": \"https://api.xero.com\"\n}"
            }
          }
        },
        {
          "name": "Get API Connection",
          "request": {
            "method": "GET",
            "url": "{{connectivity_url}}/v1/api-bridge/connections/{{connection_id}}",
            "header": [{ "key": "X-Tenant-ID", "value": "{{tenant_id}}" }]
          }
        },
        {
          "name": "List API Connections",
          "request": {
            "method": "GET",
            "url": "{{connectivity_url}}/v1/api-bridge/connections?legal_entity_id={{legal_entity_id}}",
            "header": [{ "key": "X-Tenant-ID", "value": "{{tenant_id}}" }]
          }
        }
      ]
    },
