  },
  "variable": [
    { "key": "tenant_id", "value": "tenant-zoiko-001" },
    { "key": "legal_entity_id", "value": "le-gb-001" },
    { "key": "connectivity_url", "value": "http://localhost:8144" },
    { "key": "banking_url", "value": "http://localhost:8145" },
    { "key": "hris_url", "value": "http://localhost:8146" },
    { "key": "tax_url", "value": "http://localhost:8147" },
    { "key": "esig_url", "value": "http://localhost:8148" },
    { "key": "feed_url", "value": "http://localhost:8149" },
    { "key": "connection_id", "value": "" },
    { "key": "bank_account_id", "value": "" },
    { "key": "hris_sync_id", "value": "" },
    { "key": "tax_interface_id", "value": "" },
    { "key": "submission_id", "value": "" },
