{
  "info": {
    "name": "ZoikoSuite Phase 7 — Extensibility & Scale",
    "_postman_id": "p7-extensibility-scale-2026",
    "description": "End-to-end API tests for all 6 Phase 7 microservices: Connectivity API Bridge, Banking Connector, HRIS Connector, Tax Authority Interface, eSignature Integration, and External Data Feed.",
